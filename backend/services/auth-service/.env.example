# =============================================================================
# AUTH SERVICE — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to git!
# Add .env to .gitignore immediately.
# =============================================================================

# Server Configuration
NODE_ENV=development
PORT=3001

# PostgreSQL Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://flowforge:flowforge123@localhost:5432/flowforge_db

# Redis
REDIS_URL=redis://localhost:6379

# =============================================================================
# JWT Secrets
# =============================================================================
# IMPORTANT: Use different secrets for access and refresh tokens!
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimum 32 characters each.
# =============================================================================
JWT_ACCESS_SECRET=change-me-to-a-very-long-random-string-at-least-32-chars-access
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=change-me-to-a-different-very-long-random-string-32-chars-refresh
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# Email (SMTP)
# =============================================================================
# For development, leave SMTP_USER empty to auto-create an Ethereal test account
# For production, use your SMTP provider (SendGrid, AWS SES, Gmail, etc.)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@flowforge.io

# Frontend URL — used in email links (verify email, reset password)
FRONTEND_URL=http://localhost:3000

# Security
# Higher = more secure but slower. 12 is the minimum for production.
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
