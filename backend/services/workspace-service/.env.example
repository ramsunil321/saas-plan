# Workspace Service — Environment Variables
NODE_ENV=development
PORT=3002

DATABASE_URL=postgresql://flowforge:flowforge123@localhost:5432/flowforge_db
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300

# RabbitMQ — format: amqp://user:password@host:port
RABBITMQ_URL=amqp://flowforge:flowforge123@localhost:5672

# JWT (must match auth-service exactly)
JWT_ACCESS_SECRET=change-me-to-a-very-long-random-string-at-least-32-chars-access

# Frontend URL for invitation links
FRONTEND_URL=http://localhost:3000

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@flowforge.io

# Invitation expiry in hours
INVITATION_EXPIRES_HOURS=72
