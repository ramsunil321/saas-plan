# =============================================================================
# FLOWFORGE — Environment Variables Template
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in the values below (especially JWT secrets and SMTP credentials)
#   3. Never commit the .env file to git — it contains secrets
#
# Add `.env` to your .gitignore:
#   echo ".env" >> .gitignore
#
# INTERVIEW QUESTION: "How do you manage secrets in a containerised app?"
#   Answer: Use environment variables injected at runtime (never baked into the
#   image). In development, a .env file loaded by Docker Compose. In production,
#   use a secrets manager (AWS Secrets Manager, HashiCorp Vault, Kubernetes
#   Secrets) or a CI/CD pipeline that injects vars at deploy time.
# =============================================================================


# =============================================================================
# POSTGRESQL
# =============================================================================
POSTGRES_USER=flowforge
POSTGRES_PASSWORD=flowforge123
POSTGRES_DB=flowforge
DATABASE_URL=postgresql://flowforge:flowforge123@postgres:5432/flowforge


# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379


# =============================================================================
# RABBITMQ
# =============================================================================
RABBITMQ_USER=flowforge
RABBITMQ_PASSWORD=flowforge123
RABBITMQ_URL=amqp://flowforge:flowforge123@rabbitmq:5672


# =============================================================================
# JWT — CHANGE THESE IN PRODUCTION
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================================================
JWT_ACCESS_SECRET=change-me-in-production-use-crypto-randomBytes-64-toString-hex
JWT_REFRESH_SECRET=change-me-also-different-from-access-secret-in-production


# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=production
FRONTEND_URL=http://localhost


# =============================================================================
# EMAIL (SMTP) — Optional. Leave SMTP_USER blank to disable emails.
# For Gmail: use an App Password (Account -> Security -> App Passwords)
# For testing: use Mailtrap (https://mailtrap.io)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@flowforge.io
